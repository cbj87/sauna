# Local development environment — sauna hardware control is disabled (no Harvia creds).
# Auth, bookings, members, presets, and the admin panel all work normally.
# Sauna on/off/set buttons will return a 502 "Harvia client not initialised" error.

APP_SECRET_KEY=local-dev-secret-not-for-production
FLASK_DEBUG=1

# Harvia credentials intentionally omitted — omit or leave blank to run without hardware
# HARVIA_USERNAME=
# HARVIA_PASSWORD=
# HARVIA_DEVICE_ID=
