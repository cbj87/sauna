HARVIA_USERNAME=cbjones.87@gmail.com
HARVIA_PASSWORD=your_myharvia_password_here
HARVIA_DEVICE_ID=464fc556-c49c-4746-8827-97c00442684e
APP_SECRET_KEY=change-me-to-a-long-random-string

# Push notifications (Web Push / VAPID)
# Generate keys once with: python generate_vapid_keys.py
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
# Optional: must be a mailto: address for VAPID claims
VAPID_CLAIMS_EMAIL=you@example.com

# Timezone for all booking logic and scheduler jobs (IANA tz name)
# Must match the timezone your family is in — Railway servers run UTC by default
APP_TIMEZONE=Australia/Sydney

# Email / password reset
# Required for the "Forgot password" reset link flow
# Supports any SMTP provider (SendGrid, Mailgun, Gmail, etc.)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key-here
SMTP_FROM=noreply@yourdomain.com
# Public URL of your app — used in reset link emails
APP_URL=https://your-app.up.railway.app

# Optional: override DB path (Railway mounts a volume at /data)
# DB_PATH=/data/sweatbox.db
# PORT=5000
